# =============================================================
# Master Pagamentos — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores.
# =============================================================

# Supabase — encontre em: Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sua-anon-key-publica"

# Service Role Key — NUNCA expor no frontend ou commitar com valor real
# Usada apenas no seed (scripts/seed.ts) e em API routes server-side
SUPABASE_SERVICE_ROLE_KEY="sua-service-role-key-secreta"
