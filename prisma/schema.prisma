generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String
  role       String     @default("CLIENT")
  phone             String?
  passwordChangedAt DateTime?
  theme             String    @default("dark")
  accentColor       String    @default("blue")
  lastLoginAt       DateTime?
  lastLoginIp       String?
  lastLoginUa       String?
  merchantId        String?
  merchant   Merchant?  @relation(fields: [merchantId], references: [id])
  auditLogs  AuditLog[]
  tickets    Ticket[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Merchant {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  document        String
  type            String   @default("ECOMMERCE")
  status          String   @default("REVIEW")
  plan            String   @default("basic")
  balance         Float    @default(0)
  pendingBalance  Float    @default(0)
  cdiRate         Float    @default(1.0)
  reservedBalance      Float    @default(0)
  blockedBalance       Float    @default(0)
  futureBalance        Float    @default(0)
  riskReservePercent   Float    @default(5.0)
  riskReleaseDays      Int      @default(30)
  riskLevel            String   @default("MEDIUM")
  riskReserveMin       Float    @default(0)
  riskReserveMax       Float    @default(0)
  riskNotes            String   @default("")
  tradeName            String?
  commercialPhone      String?
  website              String?
  instagram            String?
  segment              String?
  address              String?
  legalRepresentative  String?
  apiKey             String?  @unique
  kycDocumentUrls    String?  // JSON: KycDoc[]
  kycNotes           String   @default("")
  merchantNotes      String   @default("")
  pixKey             String?
  pixKeyType         String?
  bankName           String?
  anticipationFeePercent Float @default(2.5)
  users              User[]
  reserveReleases    ReserveRelease[]
  disputes           Dispute[]
  saleLogs           SaleLog[]
  anticipations      Anticipation[]
  webhookEndpoints   WebhookEndpoint[]
  masterScore        MasterScore?
  masterScoreAudits  MasterScoreAudit[]
  tickets            Ticket[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model FeePlan {
  id                 String   @id @default(cuid())
  name               String
  chargedPercent     Float
  chargedFixed       Float
  costPercent        Float
  costFixed          Float
  withdrawalDeadline String   @default("1 dia útil")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Dispute {
  id               String    @id @default(cuid())
  type             String    // CHARGEBACK | MED_PIX | REEMBOLSO | DISPUTA_MANUAL | BLOQUEIO_PREVENTIVO
  merchantId       String
  merchant         Merchant  @relation(fields: [merchantId], references: [id])
  saleLogId        String?   // AuditLog.id da transação vinculada
  contestedAmount  Float     // valor contestado
  blockedAmount    Float     @default(0) // valor efetivamente bloqueado no saldo
  status           String    @default("ABERTO")
  openedAt         DateTime  @default(now())
  deadline         DateTime?
  assignedTo       String?   // responsável interno
  documents        String?   // JSON string[]
  notes            String?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ReserveRelease {
  id             String    @id @default(cuid())
  merchantId     String
  merchant       Merchant  @relation(fields: [merchantId], references: [id])
  saleLogId      String    // AuditLog.id da venda original
  amount         Float     // valor reservado
  saleAmount     Float     // valor bruto da venda
  reservePercent Float     // percentual aplicado
  releaseDays    Int       // prazo configurado em dias
  saleDate       DateTime  // data/hora da venda
  releaseAt      DateTime  // data prevista de liberação
  status         String    @default("RESERVADO") // RESERVADO | LIBERADO | BLOQUEADO | DISPUTA | CANCELADO
  releasedAt     DateTime? // data efetiva de liberação
  releasedBy     String?   // userId que liberou manualmente
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SaleLog {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  amount      Float
  type        String   // VENDA | ESTORNO | MED_PIX | REEMBOLSO | PIX_DEVOLVIDO
  status      String   @default("APROVADO") // APROVADO | CANCELADO | PENDENTE
  feeAmount   Float    @default(0) // taxa cobrada do seller (chargedPct × amount + chargedFixed)
  feeCost     Float    @default(0) // custo da plataforma (costPct × amount + costFixed)
  description String?
  externalId  String?
  disputeId   String?
  metadata    String?  // JSON: { source?: "api" | "admin" | "internal" }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  String?
  createdAt DateTime @default(now())
}

model MasterScore {
  id                   String   @id @default(cuid())
  merchantId           String   @unique
  merchant             Merchant @relation(fields: [merchantId], references: [id])

  // Score geral (0–100)
  scoreTotal           Float    @default(0)
  nivelScore           String   @default("Bronze")   // Bronze | Prata | Ouro | Diamante
  statusRisco          String   @default("Alto risco") // Alto risco | Atenção | Saudável | Premium

  // Sub-scores parciais (0–100 cada)
  volumeScore          Float    @default(0)
  chargebackScore      Float    @default(100)
  medScore             Float    @default(100)
  reembolsoScore       Float    @default(100)
  saldoScore           Float    @default(0)
  crescimentoScore     Float    @default(50)
  tempoContaScore      Float    @default(0)
  margemScore          Float    @default(50)

  // Metadados
  dataUltimaAtualizacao DateTime @default(now())
  observacaoInterna    String?

  // Controles manuais do ADM
  monitorado           Boolean  @default(false)
  estrategico          Boolean  @default(false)
  beneficioCongelado   Boolean  @default(false)
  nivelManual          String?
  sugestaoStatus       String   @default("pendente") // pendente | ignorada | aplicada

  // Histórico de alterações
  history              MasterScoreHistory[]

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model MasterScoreHistory {
  id              String   @id @default(cuid())
  merchantId      String
  masterScore     MasterScore @relation(fields: [merchantId], references: [merchantId])

  // Scores antes e depois
  scoreBefore     Float
  scoreAfter      Float
  nivelBefore     String
  nivelAfter      String
  statusBefore    String
  statusAfter     String

  // Sub-scores após o recálculo (para reconstituição do estado)
  volumeScore     Float
  chargebackScore Float
  medScore        Float
  reembolsoScore  Float
  saldoScore      Float
  crescimentoScore Float
  tempoContaScore Float
  margemScore     Float

  // Análise dos motivos (JSON: string[])
  motivosAlteracao String   // JSON string[]

  // Contexto
  triggerMotivo   String   @default("recalculo_manual") // recalculo_manual | recalculo_em_lote | api
  observacao      String?

  createdAt       DateTime @default(now())
}

model WebhookEndpoint {
  id         String   @id @default(cuid())
  merchantId String
  merchant   Merchant @relation(fields: [merchantId], references: [id])
  url        String
  events     String   // JSON: string[]
  secret     String
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([merchantId])
}

model MasterScoreAudit {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  adminEmail  String
  adminName   String
  acao        String   // OBSERVACAO | MONITORADO | ESTRATEGICO | NIVEL_MANUAL | SUGESTAO_IGNORADA | SUGESTAO_APLICADA | BENEFICIO_CONGELADO | BENEFICIO_DESCONGELADO
  valorAntes  String?
  valorDepois String?
  motivo      String
  createdAt   DateTime @default(now())

  @@index([merchantId])
  @@index([createdAt])
}

model Anticipation {
  id              String    @id @default(cuid())
  merchantId      String
  merchant        Merchant  @relation(fields: [merchantId], references: [id])
  requestedAmount Float
  feePercent      Float
  feeAmount       Float
  netAmount       Float
  status          String    @default("PENDENTE") // PENDENTE | APROVADA | REJEITADA | CANCELADA
  notes           String?
  adminNotes      String?
  resolvedBy      String?
  resolvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([merchantId])
  @@index([status])
}

model Notification {
  id         String   @id @default(cuid())
  merchantId String
  type       String
  title      String
  body       String
  metadata   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([merchantId])
  @@index([merchantId, read])
}

model Ticket {
  id          String          @id @default(cuid())
  merchantId  String
  merchant    Merchant        @relation(fields: [merchantId], references: [id])
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  subject     String
  category    String          @default("Outro")
  // ABERTO | EM_ANALISE | AGUARDANDO_CLIENTE | RESPONDIDO | FECHADO | REABERTO
  status      String          @default("ABERTO")
  // BAIXA | MEDIA | ALTA | URGENTE
  priority    String          @default("MEDIA")
  assignedTo  String?
  slaDueAt    DateTime?
  closedAt    DateTime?
  messages    TicketMessage[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([merchantId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

model TicketMessage {
  id             String  @id @default(cuid())
  ticketId       String
  ticket         Ticket  @relation(fields: [ticketId], references: [id])
  senderId       String
  senderRole     String  // SELLER | ADMIN
  message        String
  isInternalNote Boolean @default(false)
  createdAt      DateTime @default(now())

  @@index([ticketId])
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Status: PENDING | CREDITED | CANCELLED | ERROR
model CdiCycle {
  id            String    @id @default(cuid())
  status        String    @default("PENDING")
  previewData   String    // JSON blob
  generatedAt   DateTime  @default(now())
  generatedById String
  approvedAt    DateTime?
  approvedById  String?
  creditedAt    DateTime?
  creditedById  String?
  cancelledAt   DateTime?
  cancelledById String?
  errorMessage  String?
  count         Int?
  totalCredited Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([generatedAt])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  endpointId String
  merchantId String
  event      String
  url        String
  payload    String
  statusCode Int?
  response   String?
  error      String?
  attempt    Int      @default(1)
  success    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([merchantId])
  @@index([endpointId])
  @@index([event])
  @@index([success])
  @@index([createdAt])
}
