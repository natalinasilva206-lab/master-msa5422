generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String
  role       Role       @default(CLIENT)
  merchantId String?
  merchant   Merchant?  @relation(fields: [merchantId], references: [id])
  auditLogs  AuditLog[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Merchant {
  id        String         @id @default(cuid())
  name      String
  email     String         @unique
  document  String
  type      MerchantType   @default(ECOMMERCE)
  status    MerchantStatus @default(REVIEW)
  plan      String         @default("basic")
  users     User[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model FeePlan {
  id             String   @id @default(cuid())
  name           String
  chargedPercent Float
  chargedFixed   Float
  costPercent    Float
  costFixed      Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  String?
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  CLIENT
}

enum MerchantType {
  ECOMMERCE
  INFOPRODUTOR
}

enum MerchantStatus {
  ACTIVE
  BLOCKED
  REVIEW
}
