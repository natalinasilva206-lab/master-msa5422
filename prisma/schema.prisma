generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String
  role       String     @default("CLIENT")
  phone             String?
  passwordChangedAt DateTime?
  theme             String    @default("dark")
  accentColor       String    @default("blue")
  lastLoginAt       DateTime?
  lastLoginIp       String?
  lastLoginUa       String?
  merchantId        String?
  merchant   Merchant?  @relation(fields: [merchantId], references: [id])
  auditLogs  AuditLog[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Merchant {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  document        String
  type            String   @default("ECOMMERCE")
  status          String   @default("REVIEW")
  plan            String   @default("basic")
  balance         Float    @default(0)
  pendingBalance  Float    @default(0)
  cdiRate         Float    @default(1.0)
  reservedBalance      Float    @default(0)
  blockedBalance       Float    @default(0)
  futureBalance        Float    @default(0)
  riskReservePercent   Float    @default(5.0)
  riskReleaseDays      Int      @default(30)
  riskLevel            String   @default("MEDIUM")
  riskReserveMin       Float    @default(0)
  riskReserveMax       Float    @default(0)
  riskNotes            String   @default("")
  tradeName            String?
  commercialPhone      String?
  website              String?
  instagram            String?
  segment              String?
  address              String?
  legalRepresentative  String?
  users           User[]
  reserveReleases ReserveRelease[]
  disputes        Dispute[]
  saleLogs        SaleLog[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FeePlan {
  id             String   @id @default(cuid())
  name           String
  chargedPercent Float
  chargedFixed   Float
  costPercent    Float
  costFixed      Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Dispute {
  id               String    @id @default(cuid())
  type             String    // CHARGEBACK | MED_PIX | REEMBOLSO | DISPUTA_MANUAL | BLOQUEIO_PREVENTIVO
  merchantId       String
  merchant         Merchant  @relation(fields: [merchantId], references: [id])
  saleLogId        String?   // AuditLog.id da transação vinculada
  contestedAmount  Float     // valor contestado
  blockedAmount    Float     @default(0) // valor efetivamente bloqueado no saldo
  status           String    @default("ABERTO")
  openedAt         DateTime  @default(now())
  deadline         DateTime?
  assignedTo       String?   // responsável interno
  documents        String?   // JSON string[]
  notes            String?
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ReserveRelease {
  id             String    @id @default(cuid())
  merchantId     String
  merchant       Merchant  @relation(fields: [merchantId], references: [id])
  saleLogId      String    // AuditLog.id da venda original
  amount         Float     // valor reservado
  saleAmount     Float     // valor bruto da venda
  reservePercent Float     // percentual aplicado
  releaseDays    Int       // prazo configurado em dias
  saleDate       DateTime  // data/hora da venda
  releaseAt      DateTime  // data prevista de liberação
  status         String    @default("RESERVADO") // RESERVADO | LIBERADO | BLOQUEADO | DISPUTA | CANCELADO
  releasedAt     DateTime? // data efetiva de liberação
  releasedBy     String?   // userId que liberou manualmente
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SaleLog {
  id          String   @id @default(cuid())
  merchantId  String
  merchant    Merchant @relation(fields: [merchantId], references: [id])
  amount      Float
  type        String   // VENDA | ESTORNO | MED_PIX | REEMBOLSO | PIX_DEVOLVIDO
  status      String   @default("APROVADO") // APROVADO | CANCELADO | PENDENTE
  description String?
  externalId  String?
  disputeId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  metadata  String?
  createdAt DateTime @default(now())
}
